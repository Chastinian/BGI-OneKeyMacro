<Window x:Class="BetterGenshinImpact.OneKeyMacro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:BetterGenshinImpact.OneKeyMacro.ViewModel"
        Title="一键宏（按角色）" Width="700" Height="650"
        MinWidth="550" MinHeight="500"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        mc:Ignorable="d">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 角色选择 -->
        <GroupBox Grid.Row="0" Header="角色选择" Margin="0,0,0,8">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="当前角色:" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding AvatarNames}"
                          SelectedItem="{Binding SelectedAvatarName, Mode=TwoWay}"
                          IsEditable="True" IsTextSearchEnabled="True"/>
                <ComboBox Grid.Column="2" Width="60" Margin="8,0,0,0"
                          ItemsSource="{Binding MacroPriorities}"
                          SelectedItem="{Binding SelectedMacroPriorityStr, Mode=TwoWay}"/>
            </Grid>
        </GroupBox>

        <!-- 热键设置 -->
        <GroupBox Grid.Row="1" Header="快捷键设置" Margin="0,0,0,8">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="热键:" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Width="120" Text="{Binding HotkeyString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="  模式:" Margin="8,0,8,0"/>
                <ComboBox Grid.Column="3" Width="80" ItemsSource="{Binding HotkeyModes}"
                          SelectedItem="{Binding SelectedHotkeyMode, Mode=TwoWay}"/>
                <CheckBox Grid.Column="5" Content="启用" IsChecked="{Binding IsEnabled, Mode=TwoWay}"/>
            </Grid>
        </GroupBox>

        <!-- 宏脚本编辑 -->
        <GroupBox Grid.Row="2" Header="宏脚本" Margin="0,0,0,8">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                    <Button Content="打开" Command="{Binding LoadScriptFromFileCommand}" Margin="0,0,4,0" Width="60"/>
                    <Button Content="保存" Command="{Binding SaveScriptToFileCommand}" Margin="0,0,4,0" Width="60"/>
                    <Button Content="加载角色配置" Command="{Binding LoadMacroConfigCommand}" Margin="0,0,4,0" Width="100"/>
                    <Button Content="保存角色配置" Command="{Binding SaveMacroConfigCommand}" Margin="0,0,4,0" Width="100"/>
                    <Button Content="帮助" Command="{Binding OpenHelpUrlCommand}" Margin="0,0,4,0" Width="60"/>
                </StackPanel>
                <TextBox Grid.Row="1" Height="200"
                         Text="{Binding MacroScript, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>
            </Grid>
        </GroupBox>

        <!-- 脚本语法 -->
        <GroupBox Grid.Row="3" Header="脚本语法参考" Margin="0,0,0,8">
            <TextBlock Margin="8" TextWrapping="Wrap" FontSize="11">
                指令以逗号分隔: attack, wait(0.3), dash, jump, attack(1)
                常用: attack(2) charge(1.5) dash jump walk(w,0.5) wait(0.3)
                moveby(100,0) mousedown/mouseup/click keydown(D)/keyup(D)/keypress(D) scroll(1)
                round(1-3)|...  以|分隔不同回合的指令块
            </TextBlock>
        </GroupBox>

        <!-- 控制 -->
        <Grid Grid.Row="5" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="{Binding StatusText}"/>
            <Button Grid.Column="1" Width="120" Height="36"
                    Command="{Binding StartStopCommand}"
                    Content="启动 / 停止" FontSize="14"/>
        </Grid>
    </Grid>
</Window>